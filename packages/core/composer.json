{
    "name": "sentinelphp/core",
    "description": "SentinelPHP core library - HTTP client wrapper for intercepting and storing API calls with PII redaction and schema generation",
    "type": "library",
    "license": "MIT",
    "keywords": ["sentinel", "api", "monitoring", "schema", "drift", "http-client", "interceptor", "logging"],
    "homepage": "https://github.com/SentinelPHP/core",
    "authors": [
        {
            "name": "SentinelPHP Contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/SentinelPHP/core/issues",
        "source": "https://github.com/SentinelPHP/core"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../redact"
        },
        {
            "type": "path",
            "url": "../schema"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^2.0 || ^3.0",
        "sentinelphp/redact": "@dev",
        "sentinelphp/schema": "@dev"
    },
    "require-dev": {
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Required for GuzzleMiddleware support",
        "sentinelphp/drift": "For API drift detection",
        "sentinelphp/encrypt": "For data encryption",
        "sentinelphp/dto": "For DTO code generation"
    },
    "autoload": {
        "psr-4": {
            "SentinelPHP\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SentinelPHP\\Core\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
