{
    "name": "sentinelphp/drift",
    "description": "API schema drift detection and classification library",
    "type": "library",
    "license": "MIT",
    "keywords": ["api", "drift", "schema", "detection", "monitoring"],
    "homepage": "https://github.com/SentinelPHP/drift",
    "authors": [
        {
            "name": "SentinelPHP Contributors"
        }
    ],
    "support": {
        "issues": "https://github.com/SentinelPHP/drift/issues",
        "source": "https://github.com/SentinelPHP/drift"
    },
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "SentinelPHP\\Drift\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SentinelPHP\\Drift\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
