{% extends 'dashboard/layout.html.twig' %}

{% block page_title %}User: {{ user.email }}{% endblock %}
{% block header_title %}User Details{% endblock %}

{% block header_actions %}
    <a href="{{ path('dashboard_users') }}" class="btn btn-outline-secondary btn-sm me-2">
        <i class="bi bi-arrow-left me-1"></i>Back to Users
    </a>
    {% if not user.isAdmin %}
        <a href="{{ path('dashboard_users_permissions', {id: user.id}) }}" class="btn btn-primary btn-sm">
            <i class="bi bi-shield-lock me-1"></i>Manage Permissions
        </a>
    {% endif %}
{% endblock %}

{% block content %}
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">User Information</h5>
                </div>
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="bi bi-person-circle fs-1 text-muted"></i>
                        </div>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">{{ user.email }}</dd>

                        <dt class="col-sm-4">Role</dt>
                        <dd class="col-sm-8">
                            {% if user.isAdmin %}
                                <span class="badge bg-danger">Admin</span>
                            {% else %}
                                <span class="badge bg-secondary">User</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-4">Created</dt>
                        <dd class="col-sm-8">{{ user.createdAt|date('M j, Y H:i') }}</dd>

                        <dt class="col-sm-4">Last Login</dt>
                        <dd class="col-sm-8">
                            {% if user.lastLoginAt %}
                                {{ user.lastLoginAt|date('M j, Y H:i') }}
                            {% else %}
                                <span class="text-muted">Never</span>
                            {% endif %}
                        </dd>

                        <dt class="col-sm-4">User ID</dt>
                        <dd class="col-sm-8">
                            <code class="small">{{ user.id }}</code>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">Token Access</h5>
                    {% if not user.isAdmin %}
                        <a href="{{ path('dashboard_users_permissions', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                    {% endif %}
                </div>
                <div class="card-body p-0">
                    {% if user.isAdmin %}
                        <div class="alert alert-info m-3 mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            Admin users have access to all tokens by default.
                        </div>
                    {% elseif tokenAccess|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Token Name</th>
                                        <th>Mode</th>
                                        <th>Status</th>
                                        <th>Granted</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for access in tokenAccess %}
                                        <tr>
                                            <td>
                                                <span class="text-decoration-none">
                                                    <i class="bi bi-key me-2 text-muted"></i>
                                                    {{ access.token.name }}
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-{{ access.token.mode.value == 'learning' ? 'info' : (access.token.mode.value == 'validating' ? 'success' : 'secondary') }}">
                                                    {{ access.token.mode.value|capitalize }}
                                                </span>
                                            </td>
                                            <td>
                                                {% if access.token.isActive %}
                                                    <span class="status-indicator status-green me-1"></span>Active
                                                {% else %}
                                                    <span class="status-indicator status-red me-1"></span>Inactive
                                                {% endif %}
                                            </td>
                                            <td>
                                                <small class="text-muted">{{ access.createdAt|date('M j, Y') }}</small>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-key fs-1 d-block mb-2"></i>
                            <p class="mb-3">No token access granted.</p>
                            <a href="{{ path('dashboard_users_permissions', {id: user.id}) }}" class="btn btn-primary btn-sm">
                                <i class="bi bi-plus-circle me-1"></i>Grant Access
                            </a>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
