<div 
    {{ attributes }}
    data-poll="delay(30000)|$render"
>
    <div class="card h-100">
        <div class="card-header d-flex justify-content-between align-items-center py-2">
            <div class="d-flex align-items-center">
                <h6 class="card-title mb-0">Latency</h6>
                <span class="badge bg-{{ this.trend == 'improving' ? 'success' : (this.trend == 'degrading' ? 'danger' : 'secondary') }} ms-2">
                    <i class="{{ this.trendIcon }}"></i>
                    {{ this.trendLabel }}
                </span>
            </div>
            <button 
                type="button" 
                class="btn btn-sm btn-link text-secondary p-0"
                data-action="live#action"
                data-live-action-param="refresh"
                title="Refresh data"
            >
                <i class="bi bi-arrow-clockwise"></i>
            </button>
        </div>
        <div class="card-body p-3">
            {% set percentiles = this.percentiles %}
            {% set rollingAvg = this.rollingAverages %}
            
            <div class="row g-2 mb-3">
                <div class="col-4 text-center">
                    <div class="small text-muted">P50</div>
                    <div class="fw-semibold">{{ percentiles.p50 }}ms</div>
                </div>
                <div class="col-4 text-center border-start border-end">
                    <div class="small text-muted">P95</div>
                    <div class="fw-semibold">{{ percentiles.p95 }}ms</div>
                </div>
                <div class="col-4 text-center">
                    <div class="small text-muted">P99</div>
                    <div class="fw-semibold">{{ percentiles.p99 }}ms</div>
                </div>
            </div>

            {% set timeSeriesData = this.timeSeriesData %}
            {% if timeSeriesData|length > 0 %}
                <canvas 
                    data-controller="latency-sparkline"
                    data-latency-sparkline-data-value="{{ timeSeriesData|json_encode }}"
                    data-latency-sparkline-threshold-yellow-value="{{ this.thresholdYellow }}"
                    data-latency-sparkline-threshold-red-value="{{ this.thresholdRed }}"
                    data-latency-sparkline-show-percentiles-value="{{ this.showPercentiles ? 'true' : 'false' }}"
                    data-latency-sparkline-height-value="{{ this.height }}"
                    style="height: {{ this.height }}px;"
                ></canvas>
            {% else %}
                <div class="d-flex align-items-center justify-content-center text-muted" style="height: {{ this.height }}px;">
                    <div class="text-center">
                        <i class="bi bi-graph-up fs-3 d-block mb-2"></i>
                        <small>No latency data available</small>
                    </div>
                </div>
            {% endif %}

            {% if rollingAvg['1m'] is not null or rollingAvg['5m'] is not null or rollingAvg['1h'] is not null %}
                <div class="mt-3 pt-3 border-top">
                    <div class="small text-muted mb-2">Rolling Averages</div>
                    <div class="d-flex justify-content-between small">
                        <span>
                            <span class="text-muted">1m:</span>
                            <span class="fw-medium">{{ rollingAvg['1m'] ?? '-' }}ms</span>
                        </span>
                        <span>
                            <span class="text-muted">5m:</span>
                            <span class="fw-medium">{{ rollingAvg['5m'] ?? '-' }}ms</span>
                        </span>
                        <span>
                            <span class="text-muted">1h:</span>
                            <span class="fw-medium">{{ rollingAvg['1h'] ?? '-' }}ms</span>
                        </span>
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
