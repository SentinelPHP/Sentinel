# define your env variables for the test env here
KERNEL_CLASS='App\Kernel'
APP_SECRET='$ecretf0rt3st'

# Database and Redis URLs are environment-specific:
# - CI: Set via workflow env vars
# - DDEV: Set in .env.test.local (gitignored)

# Proxy settings
PROXY_TIMEOUT=30.0
PROXY_CONNECT_TIMEOUT=10.0
HEALTH_CHECK_URL=https://httpbin.org/status/200
STATUS_ALLOWED_IPS='["127.0.0.1", "::1"]'
LOG_LEVEL=metadata_only

# Messenger
MESSENGER_TRANSPORT_DSN=sync://

# Data Protection
SENTINEL_ENCRYPTION_KEY="IBQhz2YDLu/ZOPsEg7+Ashihnprysno/eZEq/Q4G+Rc="
SENTINEL_DATA_PROTECTION_STRATEGY=none

# Alerting (empty = disabled for tests)
SLACK_ALERT_WEBHOOK_URL=""
WEBHOOK_ALERT_URL=""

###> symfony/panther ###
PANTHER_APP_ENV=test
PANTHER_ERROR_SCREENSHOT_DIR=./var/error-screenshots
PANTHER_DEVTOOLS=0
