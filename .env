# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=prod
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> trusted proxies ###
# Trust proxy headers for SSL termination. Use REMOTE_ADDR for Docker/nginx.
TRUSTED_PROXIES=REMOTE_ADDR
###< trusted proxies ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://db:db@db:5432/db?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> redis ###
REDIS_URL="redis://redis:6379"
###< redis ###

###> sentinel ###
PROXY_LISTEN_PORT=8080
PROXY_TIMEOUT=30.0
PROXY_CONNECT_TIMEOUT=10.0
LOG_LEVEL=metadata_only
HEALTH_CHECK_URL=https://httpbin.org/status/200
# JSON array of allowed IPs/CIDR ranges for /status endpoint. Use null for default private ranges.
STATUS_ALLOWED_IPS=null
# Minimum number of samples before a learned schema is considered stable
SCHEMA_LEARNING_MIN_SAMPLES=10
# TTL for cached master schemas in seconds (default: 3600 = 1 hour)
SCHEMA_CACHE_TTL=3600
# Encryption key for data protection (base64-encoded 32 bytes)
# Generate with: bin/console sentinel:encryption:generate-key
SENTINEL_ENCRYPTION_KEY=
# Data protection strategy: none, redact, encrypt, redact_encrypt
# Can be overridden per-token via ApiToken.dataProtectionStrategy
SENTINEL_DATA_PROTECTION_STRATEGY=none
# Custom PII redaction patterns (JSON object)
# Example: SENTINEL_REDACTION_PATTERNS='{"custom_id":{"pattern":"/\\bID_[A-Z0-9]{8}\\b/","replacement":"[REDACTED]"}}'
SENTINEL_REDACTION_PATTERNS=
# Additional field paths to redact (JSON array of JSONPath-like strings)
# Example: SENTINEL_REDACTION_FIELD_PATHS='["$.custom_secret","$.nested.api_key"]'
SENTINEL_REDACTION_FIELD_PATHS=
# Enable default PII patterns (credit cards, emails, phones, SSNs, API keys)
SENTINEL_REDACTION_ENABLE_DEFAULTS=true
# Retention policy: auto-delete logs older than N days (0 = disabled)
SENTINEL_RETENTION_DAYS=90
SENTINEL_RETENTION_BATCH_SIZE=1000
# Compress request/response bodies in full_audit mode (gzip)
SENTINEL_COMPRESS_AUDIT_LOGS=false
###< sentinel ###

###> alerting ###
# Slack webhook URL for drift alerts (leave empty to disable)
SLACK_ALERT_WEBHOOK_URL=
# Maximum Slack alerts per minute (rate limiting)
SLACK_ALERT_RATE_LIMIT=10
# Generic webhook URL for drift alerts (leave empty to disable)
WEBHOOK_ALERT_URL=
# Maximum retry attempts for webhook alerts
WEBHOOK_ALERT_MAX_RETRIES=3
# Base delay in milliseconds for exponential backoff
WEBHOOK_ALERT_BASE_DELAY_MS=1000
###< alerting ###

###> swoole ###
SWOOLE_HOST=0.0.0.0
SWOOLE_WORKER_NUM=4
SWOOLE_MAX_REQUEST=10000
SWOOLE_GRACEFUL_SHUTDOWN_TIMEOUT=30
###< swoole ###

###> docker/postgres ###
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
POSTGRES_DB=sentinel
###< docker/postgres ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
# Number of messenger worker replicas in production (Docker Compose)
WORKER_REPLICAS=5
###< symfony/messenger ###

###> symfony/mercure-bundle ###
# The URL of the Mercure hub, used by the app to publish updates (internal URL)
MERCURE_URL=http://mercure/.well-known/mercure
# The public URL of the Mercure hub, used by the browser to connect
MERCURE_PUBLIC_URL=https://sentinelphp.ddev.site/.well-known/mercure
# The secret used to sign the JWTs (change in production!)
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

###> dto-generation ###
# Default namespace for generated DTO classes
SENTINEL_DTO_NAMESPACE=App\Dto\Generated
# Output directory for exported DTO files (relative to project root)
SENTINEL_DTO_OUTPUT_DIR=src/Dto/Generated
# Enable automatic DTO generation when schemas are promoted
SENTINEL_DTO_AUTO_GENERATE=false
###< dto-generation ###
